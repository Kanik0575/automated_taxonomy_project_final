# Project-specific: never ship synthetic test data as if it were real
# If someone runs tools/generate_test_corpus.py, they overwrite data/papers.csv
# with fakes - don't commit that.
data/papers.csv
data/papers.json
data/rejected_log.csv

# Outputs: regenerate locally from real data. Committing fake-data outputs
# would repeat the mistake of the previous project version.
outputs/figures/*.png
outputs/reports/*.md
outputs/reports/*.csv
outputs/reports/*.json
